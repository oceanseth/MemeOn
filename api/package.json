{
  "name": "memeon-api",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "dev": "tsx watch src/local-server.ts",
    "build": "tsc --project tsconfig.json --noEmit",
    "bundle": "esbuild src/handler.ts --bundle --platform=node --target=node20 --outfile=dist/handler.mjs --format=esm --external:@aws-sdk/* --banner:js=\"import { createRequire } from 'module'; const require = createRequire(import.meta.url);\"",
    "package": "npm run bundle && bestzip lambda.zip dist/handler.mjs",
    "clean": "rimraf dist lambda.zip"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.700.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/client-ssm": "^3.700.0",
    "@aws-sdk/lib-dynamodb": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.1080.0",
    "jimp": "^1.6.0",
    "jose": "^5.9.6"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.147",
    "@types/express": "^4.17.21",
    "@types/node": "^20.17.12",
    "bestzip": "^2.2.1",
    "esbuild": "^0.24.0",
    "express": "^4.21.1",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.1",
    "typescript": "~5.9.3"
  }
}
